{
    "name": "trading-backend",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint src/ tests/",
        "lint:fix": "eslint src/ tests/ --fix",
        "clean": "rimraf dist",
        "db:migrate": "npx @better-auth/cli@1.4.21 migrate --config src/lib/auth.ts",
        "db:migrate:run": "node dist/migrate.js"
    },
    "dependencies": {
        "@fastify/cookie": "^10.0.1",
        "@fastify/cors": "^10.1.0",
        "better-auth": "^1.4.21",
        "dotenv": "^16.4.5",
        "fastify": "^5.8.5",
        "node-cache": "^5.1.2",
        "pg": "^8.13.1",
        "ws": "^8.18.0",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@tradedash/eslint-config": "*",
        "@types/node": "^20.17.6",
        "@types/pg": "^8.11.10",
        "@types/supertest": "^6.0.2",
        "@types/ws": "^8.5.13",
        "rimraf": "^6.0.1",
        "supertest": "^7.0.0",
        "tsx": "^4.19.1",
        "typescript": "^5.6.3",
        "vitest": "^4.1.4"
    }
}